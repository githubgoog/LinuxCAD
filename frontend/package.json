{
  "name": "linuxcad-frontend",
  "version": "0.3.0",
  "private": true,
  "description": "LinuxCAD Electron + React + TypeScript frontend",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "web:build": "vite build",
    "build": "npm run web:build",
    "web:preview": "vite preview",
    "build:rust": "node scripts/build-rust-backend.cjs",
    "electron:software": "node scripts/electron-dev.cjs",
    "electron:software:safe": "cross-env ELECTRON_DISABLE_GPU=1 node scripts/electron-dev.cjs --safe",
    "electron:dev": "node scripts/electron-dev.cjs",
    "electron:dev:safe": "cross-env ELECTRON_DISABLE_GPU=1 node scripts/electron-dev.cjs --safe",
    "electron:build": "npm run build:rust && npm run web:build && node scripts/electron-build.cjs",
    "electron:build:linux": "npm run build:rust && npm run web:build && node scripts/electron-build.cjs --linux",
    "electron:build:mac": "npm run build:rust && npm run web:build && node scripts/electron-build.cjs --mac",
    "electron:build:win": "npm run build:rust && npm run web:build && node scripts/electron-build.cjs --win"
  },
  "dependencies": {
    "@react-three/drei": "^9.120.0",
    "@react-three/fiber": "^8.17.12",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "three-bvh-csg": "^0.0.18",
    "three-csg-ts": "^3.2.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.linuxcad.desktop",
    "productName": "LinuxCAD",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend-rust/target/release",
        "to": "backend",
        "filter": [
          "server",
          "server.exe"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Graphics",
      "icon": "electron/assets/icons/png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.graphics-design",
      "icon": "electron/assets/icons/png/512x512.png"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "electron/assets/icons/png/512x512.png"
    }
  }
}
