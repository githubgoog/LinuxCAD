#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
FRONTEND_DIR="$ROOT_DIR/frontend"
NODE_BIN_DIR="/home/sabastian/.local/node/bin"

MODE="source"
RELEASE_ASSET="appimage"
REPO_OVERRIDE=""
INSTALL_DEB=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --launch)
      LAUNCH_AFTER_UPDATE=1
      shift
      ;;
    --release)
      MODE="release"
      shift
      ;;
    --source)
      MODE="source"
      shift
      ;;
    --asset)
      RELEASE_ASSET="${2:-}"
      shift 2
      ;;
    --repo)
      REPO_OVERRIDE="${2:-}"
      shift 2
      ;;
    --install-deb)
      INSTALL_DEB=1
      shift
      ;;
    --help|-h)
      cat <<EOF
Usage: ./update [options]

Modes:
  --source             Update local source checkout and rebuild (default)
  --release            Download latest packaged release artifact

Options:
  --launch             Launch LinuxCAD after update
  --asset <type>       Release asset: appimage or deb (default: appimage)
  --repo <owner/repo>  GitHub repository for latest release
  --install-deb        Install downloaded deb via sudo dpkg -i (release mode)
EOF
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      echo "Run './update --help' for usage."
      exit 1
      ;;
  esac
done

if [ -d "$NODE_BIN_DIR" ]; then
  export PATH="$NODE_BIN_DIR:$PATH"
fi

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Error: required command '$1' is not available in PATH."
    exit 1
  fi
}

need_cmd npm
need_cmd node

if [[ "$MODE" == "release" ]]; then
  UPDATE_ARGS=("$FRONTEND_DIR/scripts/update-release.cjs" "--asset" "$RELEASE_ASSET")
  if [[ -n "$REPO_OVERRIDE" ]]; then
    UPDATE_ARGS+=("--repo" "$REPO_OVERRIDE")
  fi
  if [[ "$INSTALL_DEB" -eq 1 ]]; then
    UPDATE_ARGS+=("--install-deb")
  fi

  echo "Updating from latest release artifact..."
  node "${UPDATE_ARGS[@]}"

  if [[ "${LAUNCH_AFTER_UPDATE:-0}" == "1" ]]; then
    if [[ "$RELEASE_ASSET" == "appimage" ]]; then
      exec "$HOME/.local/bin/LinuxCAD.AppImage"
    fi
    exec "$ROOT_DIR/run"
  fi
  exit 0
fi

need_cmd cargo

if git -C "$ROOT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Checking for source updates..."
  git -C "$ROOT_DIR" pull --ff-only || {
    echo "Warning: git pull failed. Continuing with local sources."
  }
fi

echo "Updating frontend dependencies..."
cd "$FRONTEND_DIR"
npm install --legacy-peer-deps

echo "Building Rust backend (release)..."
npm run build:rust

echo "Building frontend bundle..."
npm run web:build

echo "LinuxCAD update complete."
echo "Run './run' to launch, or './update --launch' to update and launch."

if [[ "${LAUNCH_AFTER_UPDATE:-0}" == "1" ]]; then
  exec "$ROOT_DIR/run"
fi
