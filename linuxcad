#!/usr/bin/env bash
# LinuxCAD user launcher (AppImage-only).
#
# Goals:
# - Never compile or run a source build.
# - Prefer stable user AppImage install path.
# - Default to safe GPU settings to reduce hangs/crashes.
#
# Env vars:
#   LINUXCAD_APPIMAGE=/path/to/LinuxCAD.AppImage
#   LINUXCAD_SAFE_MODE=1   (default) force software OpenGL
#   LINUXCAD_SAFE_MODE=0   disable software OpenGL

set -euo pipefail

log()  { printf '[linuxcad] %s
' "$*"; }
warn() { printf '[linuxcad] %s
' "$*" >&2; }

usage() {
cat <<'EOF'
LinuxCAD launcher (user mode)

Usage:
  linuxcad [app arguments]
  linuxcad --self-check
  linuxcad --help

Behavior:
  - Launches installed AppImage only (no source build fallback)
  - Safe graphics mode is ON by default to avoid startup hangs
EOF
}

pick_appimage() {
    if [ -n "${LINUXCAD_APPIMAGE:-}" ] && [ -f "$LINUXCAD_APPIMAGE" ]; then
        printf '%s
' "$LINUXCAD_APPIMAGE"; return 0
    fi

    local newest='' f
    shopt -s nullglob
    for f in "$HOME/.local/bin"/LinuxCAD-*.AppImage "$HOME/.local/bin"/LinuxCAD*.AppImage; do
        [ -f "$f" ] || continue
        if [ -z "$newest" ] || [ "$f" -nt "$newest" ]; then
            newest="$f"
        fi
    done
    shopt -u nullglob

    [ -n "$newest" ] && { printf '%s
' "$newest"; return 0; }
    return 1
}

self_check() {
    echo 'LinuxCAD self-check'
    echo '-------------------'
    echo "OS: $(uname -s)"
    echo "Arch: $(uname -m)"
    echo "Safe mode: ${LINUXCAD_SAFE_MODE:-1}"
    echo "PATH has ~/.local/bin: $([[ ":$PATH:" == *":$HOME/.local/bin:"* ]] && echo yes || echo no)"

    local appimg
    appimg="$(pick_appimage || true)"
    if [ -n "$appimg" ]; then
        echo "AppImage: $appimg"
        [ -x "$appimg" ] && echo 'Executable: yes' || echo 'Executable: no'
    else
        echo 'AppImage: not found in ~/.local/bin'
    fi

    command -v fusermount >/dev/null 2>&1 || command -v fusermount3 >/dev/null 2>&1       && echo 'FUSE helper: yes' || echo 'FUSE helper: no (install libfuse2 if launch fails)'

    echo
    if [ -z "$appimg" ]; then
        echo 'Install command:'
        echo '  curl -fsSL https://raw.githubusercontent.com/githubgoog/LinuxCAD/main/install.sh | bash'
    fi
}

if [ "${1:-}" = '--help' ] || [ "${1:-}" = '-h' ]; then
    usage
    exit 0
fi
if [ "${1:-}" = '--self-check' ]; then
    self_check
    exit 0
fi

APPIMG="$(pick_appimage || true)"
if [ -z "$APPIMG" ]; then
    warn 'No LinuxCAD AppImage found.'
    warn 'Install with:'
    warn '  curl -fsSL https://raw.githubusercontent.com/githubgoog/LinuxCAD/main/install.sh | bash'
    exit 1
fi

if [ ! -x "$APPIMG" ]; then
    chmod +x "$APPIMG" 2>/dev/null || true
fi

# Default to safe graphics mode to avoid 49% startup hangs on problematic GPUs.
if [ "${LINUXCAD_SAFE_MODE:-1}" = '1' ]; then
    export LIBGL_ALWAYS_SOFTWARE=1
    export QT_OPENGL=software
    export MESA_LOADER_DRIVER_OVERRIDE=llvmpipe
fi

log "Launching AppImage: $APPIMG"
exec "$APPIMG" "$@"
