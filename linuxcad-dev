#!/usr/bin/env bash
# LinuxCAD developer launcher.
#
# Use this from a repository checkout to build & run LinuxCAD via pixi.
# This is a thin wrapper; the real work lives in pixi.toml tasks.
#
#   ./linuxcad-dev                # configure + build + install + launch
#   ./linuxcad-dev --build-only   # configure + build + install, don't launch
#   ./linuxcad-dev --package      # also produce the OS-native artifact in dist/
#
# Requires pixi (https://pixi.sh). Install with:
#   curl -fsSL https://pixi.sh/install.sh | bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
cd "$SCRIPT_DIR"

log()  { printf '[linuxcad-dev] %s\n' "$*"; }
warn() { printf '[linuxcad-dev] %s\n' "$*" >&2; }

if ! command -v pixi >/dev/null 2>&1; then
    warn 'pixi is not installed.'
    warn 'Install it with:'
    warn '  curl -fsSL https://pixi.sh/install.sh | bash'
    exit 1
fi

DO_PACKAGE=0
DO_LAUNCH=1
ARGS=()
for arg in "$@"; do
    case "$arg" in
        --package)    DO_PACKAGE=1 ;;
        --build-only) DO_LAUNCH=0 ;;
        --help|-h)
            sed -n '1,15p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        *) ARGS+=("$arg") ;;
    esac
done

log 'Building LinuxCAD via pixi...'
pixi run linuxcad-release

if [ "$DO_PACKAGE" = "1" ]; then
    log 'Packaging artifact...'
    pixi run package
fi

if [ "$DO_LAUNCH" = "1" ]; then
    log 'Launching...'
    exec pixi run launch "${ARGS[@]}"
fi
